{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Six to Survive",
  "version": "0.0.5",
  "identifier": "com.sixtosurvive.game",
  "build": {
    "frontendDist": "./dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [{
      "title": "Six to Survive - 撑到六点",
      "width": 1280,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Game",
    "shortDescription": "打字清飞书，撑到六点下班",
    "longDescription": "8-bit Roguelike typing game"
  }
}
